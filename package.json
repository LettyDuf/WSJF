{
  "name": "outil-wsjf",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Outil de priorisation WSJF — architecture hexagonale, build single-file HTML pour distribution Confluence / SharePoint / local.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.5.0",
    "@vitest/coverage-v8": "^2.1.1",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.6",
    "vite-plugin-singlefile": "^2.0.2",
    "vitest": "^2.1.1"
  }
}
